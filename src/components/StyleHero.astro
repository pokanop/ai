---
/**
 * StyleHero — Hero section for image prompt style pages
 *
 * Displays the hero image, "best for" badges, and expandable sample prompt.
 */
interface Props {
  image?: string;
  bestFor?: string[];
  samplePrompt?: string;
}

const { image, bestFor = [], samplePrompt } = Astro.props;
---

<div class="style-hero">
  {image && (
    <div class="hero-image-container">
      <img src={image} alt="Style example" class="hero-image" loading="eager" />
    </div>
  )}

  {bestFor.length > 0 && (
    <div class="best-for">
      <span class="best-for-label">Best for:</span>
      <div class="best-for-badges">
        {bestFor.map((use) => (
          <span class="badge">{use}</span>
        ))}
      </div>
    </div>
  )}

  {samplePrompt && (
    <details class="sample-prompt">
      <summary class="sample-prompt-summary">
        <span class="sample-prompt-icon">✨</span>
        <span class="summary-text">Sample prompt used to generate the hero image</span>
        <button
          class="hero-copy-btn"
          data-prompt={samplePrompt}
          aria-label="Copy prompt to clipboard"
          title="Copy to clipboard"
        >
          <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="copy-text">Copy</span>
        </button>
      </summary>
      <div class="sample-prompt-content">
        <pre><code>{samplePrompt}</code></pre>
      </div>
    </details>
  )}
</div>

<script>
  function initCopyButtons() {
    const buttons = document.querySelectorAll('.hero-copy-btn');
    buttons.forEach((btn) => {
      // Only attach once
      if (btn.hasAttribute('data-initialized')) return;
      btn.setAttribute('data-initialized', 'true');
      
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        const prompt = (btn as HTMLButtonElement).dataset.prompt;
        if (!prompt) return;

        navigator.clipboard.writeText(prompt).then(() => {
          const copyIcon = btn.querySelector('.copy-icon') as SVGElement;
          const checkIcon = btn.querySelector('.check-icon') as SVGElement;
          const copyText = btn.querySelector('.copy-text') as HTMLSpanElement;

          if (copyIcon) copyIcon.style.display = 'none';
          if (checkIcon) checkIcon.style.display = 'block';
          if (copyText) copyText.textContent = 'Copied!';

          btn.classList.add('copied');

          setTimeout(() => {
            if (copyIcon) copyIcon.style.display = 'block';
            if (checkIcon) checkIcon.style.display = 'none';
            if (copyText) copyText.textContent = 'Copy';
            btn.classList.remove('copied');
          }, 2000);
        });
      });
    });
  }

  // Run on first load
  initCopyButtons();

  // If Astro View Transitions are present, run on navigation
  document.addEventListener('astro:page-load', initCopyButtons);
</script>

<style>
  .style-hero {
    margin-bottom: 2rem;
  }

  .hero-image-container {
    width: fit-content;
    margin: 0 auto 1.25rem auto;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
    display: flex;
    justify-content: center;
    align-items: center;
    background: var(--sl-color-gray-7);
  }

  .hero-image {
    max-width: 100%;
    height: auto;
    max-height: 480px;
    object-fit: contain;
    display: block;
  }

  .best-for {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .best-for-label {
    font-weight: 600;
    color: var(--sl-color-white);
    font-size: 0.875rem;
  }

  .best-for-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    background: linear-gradient(135deg, var(--sl-color-accent) 0%, var(--sl-color-accent-high) 100%);
    color: var(--sl-color-black);
    white-space: nowrap;
  }

  .sample-prompt {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    margin-bottom: 1rem;
    background: var(--sl-color-gray-6);
    overflow: hidden;
  }

  .sample-prompt-summary {
    position: relative;
    padding: 0.75rem 1rem;
    padding-right: 6rem;
    cursor: pointer;
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    user-select: none;
    transition: background-color 0.2s ease;
  }

  .sample-prompt-summary:hover {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }

  .sample-prompt[open] .sample-prompt-summary {
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .sample-prompt-icon {
    font-size: 1.125rem;
    margin-right: 0.5rem;
  }

  .sample-prompt-content {
    padding: 1rem;
  }

  .sample-prompt-content pre {
    margin: 0 !important;
    padding: 0 !important;
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    white-space: pre-wrap;
    word-break: break-word;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    font-family: var(--sl-font-mono);
  }

  .sample-prompt-content code {
    background: none;
    padding: 0;
    font-family: inherit;
  }

  .hero-copy-btn {
    display: none;
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 4px;
    background: transparent;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    font-size: 0.75rem;
    font-family: inherit;
    transition: all 0.15s ease;
    width: 6.5rem;
    flex-shrink: 0;
  }

  .sample-prompt[open] .hero-copy-btn {
    display: flex;
  }

  .hero-copy-btn > * {
    margin: 0 !important;
  }

  .hero-copy-btn:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
    background: var(--sl-color-gray-7);
  }

  .hero-copy-btn.copied {
    border-color: #10b981;
    color: #10b981;
    background: rgba(16, 185, 129, 0.1);
  }
</style>
