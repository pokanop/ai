---
/**
 * PromptBlock — A styled, copyable prompt display block
 *
 * Used across all prompt types (image, video, audio, text).
 * Features one-click copy, platform badge, use case label,
 * and optional negative prompt (collapsed for SD).
 */
interface Props {
  title?: string;
  useCase?: string;
  prompt: string;
  negativePrompt?: string;
  platform?: string;
}

const { title, useCase, prompt, negativePrompt, platform } = Astro.props;

const platformColors: Record<string, string> = {
  'Nano Banana 2': '#4f8ff7',
  'ChatGPT': '#10a37f',
  'Midjourney': '#7c5cbf',
  'Stable Diffusion': '#e67e22',
  'Veo': '#4285f4',
  'Runway Gen-3': '#ff4081',
  'Pika Labs': '#ff6b35',
  'Sora': '#1da1f2',
  'Suno': '#f5a623',
  'Udio': '#9b59b6',
  'ElevenLabs': '#2ecc71',
  'Claude': '#d97706',
  'Gemini': '#4285f4',
  'Llama': '#8b5cf6',
};

const color = platform ? (platformColors[platform] || '#6366f1') : '#6366f1';

// Highlight [PLACEHOLDERS] in the prompt for display
function highlightPlaceholders(text: string): string {
  return text.replace(/\[([A-Z][A-Z\s/—–\-,·.]+(?:\s*—\s*e\.g\.[^\]]*)?)\]/g,
    '<span class="placeholder">[$1]</span>');
}

const promptHtml = highlightPlaceholders(prompt);
const blockId = `prompt-${Math.random().toString(36).substring(2, 9)}`;
---

<div class="prompt-block" data-block-id={blockId}>
  <div class="prompt-header">
    <div class="prompt-meta">
      {title && <span class="prompt-title">{title}</span>}
      {useCase && <span class="prompt-use-case">{useCase}</span>}
    </div>
    <button
      class="copy-btn"
      data-prompt={prompt}
      aria-label="Copy prompt to clipboard"
      title="Copy to clipboard"
    >
      <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      <span class="copy-text">Copy</span>
    </button>
  </div>
  <div class="prompt-content">
    <pre><code set:html={promptHtml} /></pre>
  </div>
  {negativePrompt && (
    <details class="negative-prompt">
      <summary>Negative Prompt</summary>
      <pre><code>{negativePrompt}</code></pre>
    </details>
  )}
</div>

<script>
  // Copy prompt to clipboard
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.copy-btn') as HTMLButtonElement | null;
    if (!btn) return;

    const prompt = btn.dataset.prompt;
    if (!prompt) return;

    navigator.clipboard.writeText(prompt).then(() => {
      const copyIcon = btn.querySelector('.copy-icon') as SVGElement;
      const checkIcon = btn.querySelector('.check-icon') as SVGElement;
      const copyText = btn.querySelector('.copy-text') as HTMLSpanElement;

      if (copyIcon) copyIcon.style.display = 'none';
      if (checkIcon) checkIcon.style.display = 'block';
      if (copyText) copyText.textContent = 'Copied!';

      btn.classList.add('copied');

      setTimeout(() => {
        if (copyIcon) copyIcon.style.display = 'block';
        if (checkIcon) checkIcon.style.display = 'none';
        if (copyText) copyText.textContent = 'Copy';
        btn.classList.remove('copied');
      }, 2000);
    });
  });
</script>

<style define:vars={{ platformColor: color }}>
  .prompt-block {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 1rem;
    background: var(--sl-color-gray-7);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
    min-height: 2rem;
    gap: 0.5rem;
  }

  .prompt-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .prompt-title {
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--sl-color-white);
  }

  .prompt-use-case {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    background: var(--platformColor);
    color: white;
    font-weight: 500;
    white-space: nowrap;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 4px;
    background: transparent;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    font-size: 0.75rem;
    font-family: inherit;
    transition: all 0.15s ease;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
    background: var(--sl-color-gray-6);
  }

  .copy-btn.copied {
    border-color: #10b981;
    color: #10b981;
  }

  .prompt-content {
    padding: 0.75rem 1rem;
  }

  .prompt-content pre {
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--sl-color-gray-2);
    background: none;
    border: none;
    padding: 0;
  }

  .prompt-content code {
    background: none;
    padding: 0;
    font-family: var(--sl-font-mono);
  }

  .prompt-content :global(.placeholder) {
    color: #f59e0b;
    font-weight: 600;
    background: rgba(245, 158, 11, 0.1);
    border-radius: 3px;
    padding: 0 0.125rem;
  }

  .negative-prompt {
    border-top: 1px solid var(--sl-color-gray-5);
  }

  .negative-prompt summary {
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    user-select: none;
  }

  .negative-prompt summary:hover {
    color: var(--sl-color-gray-2);
  }

  .negative-prompt pre {
    padding: 0.5rem 1rem 0.75rem;
    margin: 0;
    font-size: 0.8125rem;
    color: #ef4444;
    white-space: pre-wrap;
    word-break: break-word;
    background: none;
    border: none;
  }

  .negative-prompt code {
    background: none;
    padding: 0;
    font-family: var(--sl-font-mono);
  }
</style>
