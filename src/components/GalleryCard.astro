---
export interface Props {
  title: string;
  image?: string;
  href: string;
  description: string;
}

const { title, image, href, description } = Astro.props;
---

<a href={href} class="gallery-card">
  {image && (
    <div class="image-wrapper">
      <img src={image} alt={title} loading="lazy" />
    </div>
  )}
  <div class="content">
    <h3 class="title">{title}</h3>
    {description && <p class="description">{description}</p>}
  </div>
</a>

<style>
  .gallery-card {
    display: flex;
    flex-direction: column;
    text-decoration: none !important;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    overflow: hidden;
    color: var(--sl-color-white) !important;
    height: 100%;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .gallery-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    border-color: var(--sl-color-accent);
  }

  .image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-7);
  }

  .image-wrapper img {
    /* Explicitly undo any starlight specific border radius on nested images */
    border-radius: 0; 
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
    display: block;
  }

  .gallery-card:hover .image-wrapper img {
    transform: scale(1.05);
  }

  .content {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .title {
    margin: 0 !important;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: !important;
    color: var(--sl-color-white);
  }
  
  .gallery-card:hover .title {
    color: var(--sl-color-accent-high);
  }

  .description {
    margin: 0 !important;
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    line-height: 1.5;
  }
</style>
